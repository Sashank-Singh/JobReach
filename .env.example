# Database (Job Service - Database A)
DATABASE_URL=postgresql+asyncpg://jobreach:jobreach@localhost:5432/jobreach
DATABASE_URL_SYNC=postgresql://jobreach:jobreach@localhost:5432/jobreach

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Fireworks AI (embeddings + resume parsing)
FIREWORKS_API_KEY=
FIREWORKS_EMBEDDING_MODEL=accounts/fireworks/models/qwen3-embedding-8b
FIREWORKS_CHAT_MODEL=accounts/fireworks/models/minimax-m3

# Auth (stored in JobReach Postgres — same DB as jobs)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_DAYS=30

# Job collection
JOB_COLLECTOR_INTERVAL_HOURS=1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
