# Database (Job Service - Database A)
DATABASE_URL=postgresql+asyncpg://jobreach:jobreach@localhost:5432/jobreach
DATABASE_URL_SYNC=postgresql://jobreach:jobreach@localhost:5432/jobreach

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Google Gemini (embeddings + resume parsing)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Auth (stored in JobReach Postgres — same DB as jobs)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_DAYS=30

# Job collection
JOB_COLLECTOR_INTERVAL_HOURS=1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
